# ═══════════════════════════════════════════════════════════════════
#  Analyst Studio — Yapılandırma
#  Bu dosyayı .env olarak kopyalayın:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── AI Erişimi (BİRİNİ seçin) ──────────────────────────────────────

# Seçenek A (ÖNERİLEN): Claude CLI — abonelik kapsamında, ücretsiz.
# Önce kurun:  npm install -g @anthropic-ai/claude-code  →  sonra: claude (giriş)
USE_CLAUDE_CLI=true

# Seçenek B: Doğrudan Anthropic API — token bazlı ücret.
# Yukarıdaki satırı silin/false yapın ve aşağıyı doldurun:
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Token / Hız Ayarları (opsiyonel) ───────────────────────────────
# HIZLI_MOD=true          # Teknik analizin AI denetçi aşamasını atlar.
#                         # Denetçi, teknik+süreç metnini İKİNCİ kez modele
#                         # gönderen en pahalı ikinci çağrıdır — 429 limitine
#                         # takılıyorsanız açın. Deterministik kapsam denetimi
#                         # (ID izlenebilirlik) her durumda çalışır.
# EXTENDED_THINKING=true  # Daha derin akıl yürütme (daha yavaş + daha çok token)
# API_CACHE=false         # Çıktı önbelleğini kapat (varsayılan açık — aynı
#                         # girdiyle tekrar çalıştırma 0 token harcar)

# ── Çalışma Modu (lokal kullanım için dokunmayın) ──────────────────
# HOST=127.0.0.1          # varsayılan: sadece yerel erişim
# AUTH_ENABLED=false      # lokal kullanımda kapalı kalır
# SECRET_KEY=...          # boş bırakın — uygulama otomatik üretir
