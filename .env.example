# Seçenek 1: Doğrudan API key
ANTHROPIC_API_KEY=sk-ant-...

# Seçenek 2: Claude Code CLI kullan (API key gerekmez)
# USE_CLAUDE_CLI=true

# ── Authentication (Paylaşımlı Sunucu) ────────────────────────────
# Lokal kullanımda false bırakın. Sunucuya geçince true yapın.
AUTH_ENABLED=false
ADMIN_USER=ugur.cangir
SECRET_KEY=buraya_rastgele_uzun_bir_string_yazin
